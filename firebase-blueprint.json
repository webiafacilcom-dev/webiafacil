{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "basico", "pro", "master"] },
        "whatsapp": { "type": "string" },
        "activationDate": { "type": "string", "format": "date-time" },
        "conversionCount": { "type": "number" },
        "maxConversions": { "type": "number" },
        "hosting": {
          "type": "object",
          "properties": {
            "url": { "type": "string" },
            "user": { "type": "string" },
            "pass": { "type": "string" },
            "plan": { "type": "string" },
            "dns1": { "type": "string" },
            "dns2": { "type": "string" },
            "dns3": { "type": "string" },
            "dns4": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Tutorial": {
      "title": "Tutorial",
      "description": "A video tutorial managed by administrators.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "videoUrl": { "type": "string" },
        "description": { "type": "string" },
        "links": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "order": { "type": "number" },
        "badge": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "videoUrl", "createdAt"]
    },
    "WhatsAppLink": {
      "title": "WhatsAppLink",
      "description": "Saved WhatsApp shortened/tracked links.",
      "type": "object",
      "properties": {
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phone", "url", "createdAt"]
    },
    "WebsiteProject": {
      "title": "WebsiteProject",
      "description": "A generated website project from the AI builder.",
      "type": "object",
      "properties": {
        "prompt": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["prompt", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "users/{userId}/whatsapp_links/{linkId}": {
      "schema": { "$ref": "#/entities/WhatsAppLink" },
      "description": "Stores WhatsApp links belonging to the user."
    },
    "users/{userId}/websites/{siteId}": {
      "schema": { "$ref": "#/entities/WebsiteProject" },
      "description": "Stores generated websites belonging to the user."
    },
    "tutorials/{tutorialId}": {
      "schema": { "$ref": "#/entities/Tutorial" },
      "description": "Stores video tutorials managed by admins."
    }
  }
}
